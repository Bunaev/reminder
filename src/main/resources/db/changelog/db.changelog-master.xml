<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="20260313-01" author="bunaev">
        <createTable tableName="tbl_users">
            <column name="id" type="BIGSERIAL" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(255)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="password" type="VARCHAR(255)">
                <constraints nullable="true"/>
            </column>
            <column name="email" type="VARCHAR(255)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="telegram" type="VARCHAR(255)">
                <constraints nullable="false" unique="true"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="20260313-02" author="bunaev">
        <createTable tableName="tbl_reminder">
            <column name="id" type="BIGSERIAL" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="title" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="VARCHAR(200)">
                <constraints nullable="false"/>
            </column>
            <column name="created" type="TIMESTAMP WITHOUT TIME ZONE">
                <constraints nullable="false"/>
            </column>
            <column name="updated" type="TIMESTAMP WITHOUT TIME ZONE"/>
            <column name="author" type="BIGINT">
                <constraints nullable="false"
                             foreignKeyName="fk_reminder_user"
                             references="tbl_users(id)"/>
            </column>
            <column name="deadline" type="TIMESTAMP WITHOUT TIME ZONE">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="20260313-03" author="bunaev">
        <createIndex indexName="idx_reminder_author" tableName="tbl_reminder">
            <column name="author"/>
        </createIndex>
        <createIndex indexName="idx_reminder_deadline" tableName="tbl_reminder">
            <column name="deadline"/>
        </createIndex>
    </changeSet>
    <changeSet id="20260317-01" author="bunaev">
        <addColumn tableName="tbl_reminder">
            <column name="email_send" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="telegram_send" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
        </addColumn>
    </changeSet>
    <changeSet id="20260318-01" author="bunaev">
        <addColumn tableName="tbl_users">
            <column name="telegram_chat_id" type="BIGINT">
                <constraints unique="true"/>
            </column>
        </addColumn>
    </changeSet>
</databaseChangeLog>